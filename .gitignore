# dev workspace
.worktrees/
.DS_Store

# env files (Supabase URL + anon key live in src/public-config.js instead)
.env*
!.env.example

# wrangler / Cloudflare local state
.wrangler
.dev.vars*
!.dev.vars.example

# secrets / credentials — NEVER commit these (the OAuth client_secret lives in
# ~/.config/fasty/ now, outside the repo). These patterns stop an accidental
# `git add .` from ever staging a secret again.
client_secret*.json
*credentials*.json
service-account*.json
*.pem
.mcp.json
