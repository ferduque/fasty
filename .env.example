# Fasty — Supabase configuration
# Copy this file to `.env` (which is gitignored) and fill in your project values.
#
# Get the values from your Supabase dashboard:
#   Settings → API → Project URL          → SUPABASE_URL
#   Settings → API → Project API keys → anon public  → SUPABASE_ANON_KEY
#
# Both values are safe to ship in client code — the anon key is meant to be
# public; Row-Level Security in the database protects user data.
# NEVER put the `service_role` key here. It bypasses RLS.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
