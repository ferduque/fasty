# Cloudflare Pages cache headers.
# index.html, JS, and CSS use ?v=N query-string busting, but the FILES themselves
# don't have versioned URLs — so we tell the CDN to revalidate on every load.
# Without this, visitors might see stale code after a deploy.

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/app.js
  Cache-Control: no-cache, max-age=0, must-revalidate

/styles.css
  Cache-Control: no-cache, max-age=0, must-revalidate

/src/*
  Cache-Control: no-cache, max-age=0, must-revalidate
